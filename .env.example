# Obsidian Local REST API Configuration
# Copy this file to .env and fill in your values

# The URL where your Obsidian Local REST API is running
# NOTE: Check your plugin settings! Default is HTTPS on port 27124
# If using HTTP (non-encrypted), the default port is 27123
OBSIDIAN_API_URL=https://127.0.0.1:27124

# Your API key from Obsidian Local REST API plugin settings
# Get this from: Obsidian Settings -> Community Plugins -> Local REST API -> API Key
OBSIDIAN_API_KEY=your_api_key_here

# Comma-separated directory names to exclude from tree_view expansion.
# Useful for large reference directories that would produce excessive output.
# Example: TREE_VIEW_EXCLUDE_DIRS=1-Mechanics,Archive,Templates
TREE_VIEW_EXCLUDE_DIRS=
